# Get your free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Ollama model to use (qwen2.5:7b is best for JSON compliance)
OLLAMA_MODEL=qwen2.5:7b

# Server port
PORT=3001

# Environment
NODE_ENV=development

# Allowed frontend origin for CORS
ALLOWED_ORIGIN=http://localhost:5173

# ─── Microsoft Outlook Integration (optional) ─────────────────────────────────
# Follow the Azure setup guide in OUTLOOK_SETUP.md to get these values.
# Leave blank to use mock emails (demo mode).

# From Azure Portal → App Registrations → Your App → Overview
MICROSOFT_CLIENT_ID=your_client_id_here

# From Azure Portal → App Registrations → Your App → Certificates & secrets
MICROSOFT_CLIENT_SECRET=your_client_secret_here

# Must match exactly what you set in Azure → Redirect URIs
# Dev:  http://localhost:3001/api/auth/callback
# Prod: https://your-railway-app.railway.app/api/auth/callback
MICROSOFT_REDIRECT_URI=http://localhost:3001/api/auth/callback

# ─── Google Gmail Integration (optional) ─────────────────────────────────────
# Follow the setup guide in GMAIL_SETUP.md to get these values.
# Leave blank to skip Gmail (Outlook or mock data will be used instead).

# From Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=your_google_client_id_here

# From Google Cloud Console → OAuth 2.0 Client ID → Client Secret
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Must match exactly what you set in Google Cloud → Authorized redirect URIs
# Dev:  http://localhost:3001/api/auth/google/callback
# Prod: https://your-railway-app.railway.app/api/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback
